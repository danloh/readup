# OAuth Configuration for ATProto/Bluesky
# 
# The client_id must be a URL pointing to your OAuth client metadata JSON.
# The app automatically serves metadata from:
# - Development: http://localhost:3000/.well-known/oauth-client-metadata.json
# - Production: https://yourdomain.com/.well-known/oauth-client-metadata.json

# REQUIRED: OAuth client ID (URL to your metadata)
# Register your app at https://bsky.app/settings/connected-apps
NEXT_PUBLIC_OAUTH_CLIENT_ID=http://localhost:3000/.well-known/oauth-client-metadata.json

# OPTIONAL: Application base URL (defaults to deduced from client_id)
# Used to generate metadata and redirect URIs
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OPTIONAL: Application display name (defaults to "Readup")
# Shown in OAuth screens
NEXT_PUBLIC_APP_NAME=Readup
