{
  "identifier": "webdriver-testing",
  "description": "Grants plugin permissions to remote URLs for Vitest browser-mode tests. Only loaded at runtime when the webdriver feature is enabled.",
  "remote": {
    "urls": ["http://127.0.0.1:*", "http://localhost:*"]
  },
  "local": false,
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:default",
    "fs:read-all",
    "fs:write-all",
    "fs:scope-appconfig-recursive",
    "fs:scope-appdata-recursive",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "**/.readup-test-sandbox-tauri" },
        { "path": "**/.readup-test-sandbox-tauri/**" },
        { "path": "**/Readup" },
        { "path": "**/Readup/**" }
      ]
    },
    "os:default",
    "dialog:default",
    "core:window:default",
    "core:path:allow-resolve-directory",
    "log:default",
    "shell:default",
    "process:default",
    "turso:default",
    "native-tts:default",
    "native-bridge:default"
  ]
}
